# Add these in local development and in the deployment environment.
OPENAI_API_KEY=
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=

# Required only for scheduled cross-tenant Pilot and Atlas operating rhythms.
# Never expose this key to the browser.
SUPABASE_SERVICE_ROLE_KEY=
CRON_SECRET=

# Northstar production application URLs.
NEXT_PUBLIC_CAPA_APP_URL=
NEXT_PUBLIC_NCR_APP_URL=

# Optional. Defaults to gpt-5.6.
OPENAI_MODEL=gpt-5.6
