# Add these in local development and in your deployment environment.
OPENAI_API_KEY=
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=

# Northstar production application URLs.
# Point this to the deployed CAPA application. The launcher uses the GitHub Pages
# address as a demo fallback when this value is not configured.
NEXT_PUBLIC_CAPA_APP_URL=

# Optional. Defaults to gpt-5.6.
OPENAI_MODEL=gpt-5.6
